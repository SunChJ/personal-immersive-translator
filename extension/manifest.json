{
  "manifest_version": 3,
  "name": "Personal Immersive Translator",
  "description": "Translate the current page through a local OpenAI proxy.",
  "version": "0.2.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Translate this page"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "permissions": ["activeTab", "scripting", "storage", "tabs"]
}
