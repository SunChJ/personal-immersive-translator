{
  "manifest_version": 3,
  "name": "Prism — Immersive Translator",
  "description": "Immersive bilingual page translation through a local Codex bridge.",
  "version": "0.2.10",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prism — Translate this page"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["route-patch.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "shared.js",
        "content-utils.js",
        "content-state.js",
        "content-detect.js",
        "content-render.js",
        "content-observers.js",
        "content-floating.js",
        "content-selection.js",
        "content-styles.js",
        "content-translate.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "permissions": ["activeTab", "scripting", "storage", "tabs"]
}
