{
  "manifest_version": 3,
  "name": "Prism — Immersive Translator",
  "description": "Immersive bilingual page translation through a local Codex bridge.",
  "version": "0.2.8",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prism — Translate this page"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "permissions": ["activeTab", "scripting", "storage", "tabs"]
}
